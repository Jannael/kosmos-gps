{
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist"],
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"paths": {
			"@/*": ["./src/*", "./../api/src/*"],
			"app": ["./../api/src/index.ts"],
			"routes": ["./../api/src/routes/index.ts"],
			"controllers": ["./../api/src/controllers/index.ts"],
			"db": ["./../api/data/index.ts"]
		}
	}
}
