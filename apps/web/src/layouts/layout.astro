---
import '@/styles/global.css'
import '@fontsource-variable/jost/wght.css'
import jostLatinWoff2 from '@fontsource-variable/jost/files/jost-latin-wght-normal.woff2?url'

type Props = {
	title?: string
	description?: string
}

const { title = 'Kosmos GPS', description = 'Soluciones de rastreo GPS para tu negocio.' } = Astro.props

const ogImageUrl = 'https://kosmosgps.com/wp-content/uploads/instalaciones-de-kosmos-en-corporativo.jpg'
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" href="/favicon.webp" />
		<link rel="preload" href={jostLatinWoff2} as="font" type="font/woff2" crossorigin />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:site_name" content="Kosmos GPS" />
		<meta property="og:locale" content="es_MX" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
	</head>
	<body>
		<main>
			<slot />
		</main>
	</body>

	<style is:global>
		html {
			font-family: 'Jost Variable', sans-serif;
		}
	</style>
</html>
